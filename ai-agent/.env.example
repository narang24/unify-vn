# ── Secrets ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GITHUB_TOKEN=your-github-token-with-actions-and-deployments-read

# ── Models / defaults ────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-3.5-flash
REPO_OWNER=narang24
REPO_NAME=TravelStory-VN
AI_AGENT_PORT=8088

# ── Long-term memory (optional; falls back to in-memory when unset) ──────────
REDIS_URL=redis://localhost:6379/0

# ── Observability integrations (optional; honest "not configured" when unset) ─
PROMETHEUS_URL=
KUBE_API_URL=
